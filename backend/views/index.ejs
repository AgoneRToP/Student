<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Students Management</title>
    <link rel="stylesheet" href="/css/style.css">
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB"
      crossorigin="anonymous"
    />
</head>
<body>
    <div class="container p-5">
        <h1 class="p-5 text-center">Управление списком студентов</h1>
        
        <table class="student-table">
            <thead>
                <%- include("components/table.ejs") %>
            </thead>
            <tbody>
                <% data.forEach((student, index) => { %>
                    <%- include("components/student-row", {student, index}) %>
                <% }) %>
                <%- include('components/add.ejs') %>
            </tbody>
        </table>
            

        <%- include("components/pagination", { page, totalPages, totalCount }) %>
    </div>
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
      crossorigin="anonymous"
    ></script>
</body>
</html>